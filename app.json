{
  "expo": {
    "name": "AlignPal",
    "slug": "alignpal",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alignpal.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for AI posture analysis"
      }
    },
    "android": {
      "package": "com.alignpal.app",
      "permissions": []
    },
    "plugins": [
      [
        "react-native-purchases",
        {
          "enableCustomEntitlementComputation": false
        }
      ]
    ]
  }
}
